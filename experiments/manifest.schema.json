{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/wavtokenize/codex-manifest.schema.json",
  "title": "Codex Agent-Native Experiment Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "experiment_id",
    "family",
    "objective",
    "hypothesis",
    "acceptance_criteria",
    "stages"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis": {
      "type": "string",
      "minLength": 1
    },
    "baseline_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "run_root": {
      "type": "string"
    },
    "default_env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "resources": {
      "type": "object"
    },
    "acceptance_criteria": {
      "type": "object"
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ]
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "adapter"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "adapter": {
            "type": "string",
            "enum": [
              "python_script",
              "shell"
            ]
          },
          "adapter_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "after": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "cwd": {
            "type": "string"
          },
          "entrypoint": {
            "type": "string"
          },
          "python": {
            "type": "string"
          },
          "args": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "number",
                "boolean"
              ]
            }
          },
          "command": {
            "type": "string"
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "resources": {
            "type": "object"
          },
          "artifacts": {
            "type": "object"
          },
          "completion": {
            "type": "object"
          }
        }
      }
    }
  }
}
