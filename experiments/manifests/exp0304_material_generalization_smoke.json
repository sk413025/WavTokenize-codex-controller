{
  "schema_version": 1,
  "experiment_id": "exp0304_material_generalization_smoke",
  "family": "material-generalization",
  "objective": "Run the first official smoke gate for exp_0304 after preflight passes.",
  "hypothesis": "A preflight-backed smoke run can validate data loading, model construction, and basic artifact emission before any longer material generalization run.",
  "baseline_refs": [
    "exp0304_material_generalization_preflight",
    "exp0304_material_generalization"
  ],
  "run_root": "controller_runs",
  "default_env": {
    "PYTHONPATH": "."
  },
  "resources": {
    "gpu": "cuda:1",
    "batch_size": 2,
    "num_workers": 0
  },
  "acceptance_criteria": {
    "required_stage_status": {
      "preflight_material_gen": "completed",
      "train_material_gen_smoke": "completed"
    },
    "required_files": [],
    "result_classification_on_pass": "candidate"
  },
  "supersedes": null,
  "stages": [
    {
      "name": "preflight_material_gen",
      "adapter": "python_script",
      "adapter_id": "exp0304_preflight_material_gen",
      "description": "Verify exp_0304 is ready for the smoke gate.",
      "entrypoint": "exp_0304/preflight_material_gen.py",
      "args": [
        "--gpu",
        "cuda:1",
        "--train_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/train_cache_filtered.pt",
        "--val_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/val_cache_filtered.pt",
        "--encoder_ckpt",
        "exp_0227/runs/enc_mrd_fm_epoch_20260227_024953/best_model_val_total.pt",
        "--report_path",
        "{run_dir}/preflight_report.json"
      ],
      "resources": {
        "gpu": "cuda:1"
      }
    },
    {
      "name": "train_material_gen_smoke",
      "adapter": "python_script",
      "adapter_id": "exp0304_train_material_gen",
      "description": "Run the first smoke gate for exp_0304 with external cache bindings and run-local output paths.",
      "after": [
        "preflight_material_gen"
      ],
      "entrypoint": "exp_0304/train_material_gen.py",
      "args": [
        "--mode",
        "smoke",
        "--epochs",
        "5",
        "--device",
        "cuda:1",
        "--batch_size",
        "2",
        "--grad_accum",
        "1",
        "--num_workers",
        "0",
        "--eval_max_batches",
        "2",
        "--save_checkpoint_every",
        "1",
        "--save_audio_interval",
        "999",
        "--train_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/train_cache_filtered.pt",
        "--val_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/val_cache_filtered.pt",
        "--encoder_ckpt",
        "exp_0227/runs/enc_mrd_fm_epoch_20260227_024953/best_model_val_total.pt",
        "--output_dir",
        "{run_dir}/exp_0304_smoke"
      ],
      "resources": {
        "gpu": "cuda:1"
      }
    }
  ]
}
