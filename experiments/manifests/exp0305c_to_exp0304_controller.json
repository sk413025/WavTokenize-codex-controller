{
  "schema_version": 1,
  "experiment_id": "exp0305c_to_exp0304_controller",
  "family": "anchor-then-material",
  "objective": "Replace the legacy exp_0305c wait-and-launch chain with a manifest-driven sequential pipeline that runs exp_0305c and then families.official.material_generalization.",
  "hypothesis": "A manifest-driven preflight-plus-sequential pipeline can safely supersede the legacy shell watcher and provide a reproducible stage handoff for anchor-then-material experiments.",
  "baseline_refs": [
    "exp0304_material_generalization"
  ],
  "run_root": "controller_runs",
  "default_env": {
    "PYTHONPATH": "."
  },
  "resources": {
    "primary_gpu": "cuda:0",
    "secondary_gpu": "cuda:1",
    "batch_size": 2,
    "num_workers": 0
  },
  "acceptance_criteria": {
    "required_stage_status": {
      "preflight_anchor_then_material": "completed",
      "train_expc": "completed",
      "train_material_gen": "completed"
    },
    "required_files": [],
    "result_classification_on_pass": "candidate"
  },
  "supersedes": "families/official/anchor_then_material/wait_and_launch_exp0304.sh",
  "stages": [
    {
      "name": "preflight_anchor_then_material",
      "adapter": "python_script",
      "adapter_id": "exp0305c_preflight_anchor_then_material",
      "description": "Check shared assets, optional material-stage checkpoint fallback, and both sequential GPUs before any chain launch.",
      "entrypoint": "families/official/anchor_then_material/preflight_anchor_then_material.py",
      "args": [
        "--primary_gpu",
        "cuda:0",
        "--secondary_gpu",
        "cuda:1",
        "--train_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/train_cache_filtered.pt",
        "--val_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/val_cache_filtered.pt",
        "--material_encoder_ckpt",
        "families/deps/enc_mrd_fm/runs/enc_mrd_fm_epoch_20260227_024953/best_model_val_total.pt",
        "--report_path",
        "{run_dir}/preflight_report.json"
      ],
      "resources": {
        "primary_gpu": "cuda:0",
        "secondary_gpu": "cuda:1"
      }
    },
    {
      "name": "train_expc",
      "adapter": "python_script",
      "adapter_id": "exp0305c_train_expc",
      "description": "Run exp_0305c anchor training as the first stage of the official official pipeline.",
      "after": [
        "preflight_anchor_then_material"
      ],
      "entrypoint": "families/official/anchor_then_material/train_expc.py",
      "args": [
        "--mode",
        "epoch",
        "--epochs",
        "300",
        "--device",
        "cuda:0",
        "--batch_size",
        "8",
        "--grad_accum",
        "2",
        "--num_workers",
        "2",
        "--eval_max_batches",
        "30",
        "--train_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/train_cache_filtered.pt",
        "--val_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/val_cache_filtered.pt",
        "--output_dir",
        "{run_dir}/exp_0305c_epoch"
      ],
      "resources": {
        "gpu": "cuda:0"
      }
    },
    {
      "name": "train_material_gen",
      "adapter": "python_script",
      "adapter_id": "exp0304_train_material_gen",
      "description": "Run exp_0304 material generalization after exp_0305c completes successfully.",
      "after": [
        "train_expc"
      ],
      "entrypoint": "families/official/material_generalization/train_material_gen.py",
      "args": [
        "--mode",
        "epoch",
        "--epochs",
        "300",
        "--device",
        "cuda:1",
        "--batch_size",
        "8",
        "--grad_accum",
        "2",
        "--num_workers",
        "2",
        "--train_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/train_cache_filtered.pt",
        "--val_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/val_cache_filtered.pt",
        "--encoder_ckpt",
        "families/deps/enc_mrd_fm/runs/enc_mrd_fm_epoch_20260227_024953/best_model_val_total.pt",
        "--output_dir",
        "{run_dir}/exp_0304_epoch"
      ],
      "resources": {
        "gpu": "cuda:1"
      }
    }
  ]
}
