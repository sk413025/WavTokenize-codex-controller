{
  "schema_version": 1,
  "experiment_id": "exp0304_material_generalization",
  "family": "material-generalization",
  "objective": "Run exp_0304 material generalization training under Codex control and capture a reproducible execution record.",
  "hypothesis": "The exp_0304 material generalization recipe can be executed reproducibly from this worktree without shell-based orchestration and can serve as the official material-generalization ladder.",
  "baseline_refs": [],
  "run_root": "controller_runs",
  "default_env": {
    "PYTHONPATH": "."
  },
  "resources": {
    "gpu": "cuda:1",
    "batch_size": 8,
    "num_workers": 2
  },
  "acceptance_criteria": {
    "required_stage_status": {
      "preflight_material_gen": "completed",
      "train_material_gen": "completed"
    },
    "required_files": [],
    "result_classification_on_pass": "candidate"
  },
  "supersedes": null,
  "stages": [
    {
      "name": "preflight_material_gen",
      "adapter": "python_script",
      "adapter_id": "exp0304_preflight_material_gen",
      "description": "Check external assets, optional encoder checkpoint fallback, and GPU readiness before the full exp_0304 launch.",
      "entrypoint": "exp_0304/preflight_material_gen.py",
      "args": [
        "--gpu",
        "cuda:1",
        "--train_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/train_cache_filtered.pt",
        "--val_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/val_cache_filtered.pt",
        "--encoder_ckpt",
        "exp_0227/runs/enc_mrd_fm_epoch_20260227_024953/best_model_val_total.pt",
        "--report_path",
        "{run_dir}/preflight_report.json"
      ],
      "resources": {
        "gpu": "cuda:1"
      }
    },
    {
      "name": "train_material_gen",
      "adapter": "python_script",
      "adapter_id": "exp0304_train_material_gen",
      "description": "Run exp_0304 material generalization training with official logs and decision state.",
      "after": [
        "preflight_material_gen"
      ],
      "entrypoint": "exp_0304/train_material_gen.py",
      "args": [
        "--mode",
        "epoch",
        "--epochs",
        "300",
        "--device",
        "cuda:1",
        "--batch_size",
        "8",
        "--grad_accum",
        "2",
        "--num_workers",
        "2",
        "--train_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/train_cache_filtered.pt",
        "--val_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/val_cache_filtered.pt",
        "--encoder_ckpt",
        "exp_0227/runs/enc_mrd_fm_epoch_20260227_024953/best_model_val_total.pt",
        "--output_dir",
        "{run_dir}/exp_0304_epoch"
      ],
      "resources": {
        "gpu": "cuda:1"
      }
    }
  ]
}
