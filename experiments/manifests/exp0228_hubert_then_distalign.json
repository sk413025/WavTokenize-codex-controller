{
  "schema_version": 1,
  "experiment_id": "exp0228_hubert_then_distalign",
  "family": "hubert-then-distalign",
  "objective": "Replace the legacy exp_0228 wait-then-start distalign watcher with a manifest-driven sequential pipeline that runs preflight, the HuBERT feature-loss stage, and then the distalign stage.",
  "hypothesis": "A manifest-driven preflight-plus-base-then-distalign pipeline can safely supersede the legacy watcher script and provide a reproducible stage handoff for future exp_0228 runs.",
  "baseline_refs": [
    "exp_0227 encoder-only MRD FM baseline",
    "exp_0228/wait_then_start_distalign.sh"
  ],
  "run_root": "controller_runs",
  "default_env": {
    "PYTHONPATH": "."
  },
  "resources": {
    "gpu": "cuda:0",
    "batch_size": 2,
    "num_workers": 0
  },
  "acceptance_criteria": {
    "required_stage_status": {
      "preflight_hubert_distalign": "completed",
      "train_enc_hubert_fm": "completed",
      "train_enc_hubert_fm_distalign": "completed"
    },
    "required_files": [],
    "result_classification_on_pass": "candidate"
  },
  "supersedes": "exp_0228/wait_then_start_distalign.sh",
  "stages": [
    {
      "name": "preflight_hubert_distalign",
      "adapter": "python_script",
      "adapter_id": "exp0228_preflight_hubert_distalign",
      "description": "Check HuBERT-stage assets, optional encoder checkpoint fallback, and GPU readiness before any exp_0228 launch.",
      "entrypoint": "exp_0228/preflight_hubert_distalign.py",
      "args": [
        "--gpu",
        "cuda:0",
        "--train_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/train_cache_filtered.pt",
        "--val_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/val_cache_filtered.pt",
        "--encoder_ckpt",
        "exp_0225/runs/no_vq_scratch_epoch_20260224_032104/best_model_val_total.pt",
        "--report_path",
        "{run_dir}/preflight_report.json"
      ],
      "resources": {
        "gpu": "cuda:0"
      }
    },
    {
      "name": "train_enc_hubert_fm",
      "adapter": "python_script",
      "adapter_id": "exp0228_train_enc_hubert_fm",
      "description": "Run the base exp_0228 HuBERT feature-loss training stage.",
      "after": [
        "preflight_hubert_distalign"
      ],
      "entrypoint": "exp_0228/train_enc_hubert_fm.py",
      "args": [
        "--mode",
        "epoch",
        "--epochs",
        "300",
        "--device",
        "cuda:0",
        "--batch_size",
        "8",
        "--grad_accum",
        "2",
        "--num_workers",
        "2",
        "--train_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/train_cache_filtered.pt",
        "--val_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/val_cache_filtered.pt",
        "--encoder_ckpt",
        "exp_0225/runs/no_vq_scratch_epoch_20260224_032104/best_model_val_total.pt",
        "--output_dir",
        "{run_dir}/exp_0228_base_epoch"
      ],
      "resources": {
        "gpu": "cuda:0"
      }
    },
    {
      "name": "train_enc_hubert_fm_distalign",
      "adapter": "python_script",
      "adapter_id": "exp0228_train_enc_hubert_fm_distalign",
      "description": "Run the follow-up distalign stage after the base HuBERT feature-loss stage completes.",
      "after": [
        "train_enc_hubert_fm"
      ],
      "entrypoint": "exp_0228/train_enc_hubert_fm_distalign.py",
      "args": [
        "--mode",
        "epoch",
        "--epochs",
        "300",
        "--device",
        "cuda:0",
        "--batch_size",
        "8",
        "--grad_accum",
        "2",
        "--num_workers",
        "2",
        "--align_type",
        "coral",
        "--lambda_dist",
        "0.2",
        "--train_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/train_cache_filtered.pt",
        "--val_cache",
        "/home/sbplab/ruizi/WavTokenize-feature-analysis/data/val_cache_filtered.pt",
        "--encoder_ckpt",
        "{run_dir}/exp_0228_base_epoch/best_model_val_total.pt",
        "--output_dir",
        "{run_dir}/exp_0228_distalign_epoch"
      ],
      "resources": {
        "gpu": "cuda:0"
      }
    }
  ]
}
