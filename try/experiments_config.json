{
  "experiment_suite": "training_speed_debug",
  "created_at": "2025-10-30",
  "purpose": "驗證 run_simple_efficient.sh 與 debug_single_sample.py 的訓練速度差異原因",

  "baseline": {
    "debug_single_sample": {
      "dataset_size": 14,
      "dropout": 0.0,
      "weight_decay": 0.0,
      "batch_size": 14,
      "learning_rate": 3e-4,
      "result": {
        "epoch_100_accuracy": "~100%",
        "convergence_speed": "fast"
      }
    },
    "run_simple_efficient_original": {
      "dataset_size": "240+",
      "dropout": 0.3,
      "weight_decay": 0.01,
      "batch_size": 14,
      "learning_rate": 3e-4,
      "result": {
        "epoch_200_accuracy": "~20%",
        "epoch_600_accuracy": "~60%",
        "convergence_speed": "very_slow"
      }
    }
  },

  "hypotheses": [
    {
      "id": 1,
      "name": "Dropout 影響",
      "description": "Dropout=0.3 導致累積資訊損失 (4層後只保留24%資訊)",
      "confidence": "high",
      "impact_estimate": "⭐⭐⭐⭐☆"
    },
    {
      "id": 2,
      "name": "Weight Decay 影響",
      "description": "Weight Decay=0.01 持續抑制權重成長",
      "confidence": "medium",
      "impact_estimate": "⭐⭐⭐☆☆"
    },
    {
      "id": 3,
      "name": "資料量影響",
      "description": "樣本數量差異 (14 vs 240+) 導致學習難度差17倍",
      "confidence": "very_high",
      "impact_estimate": "⭐⭐⭐⭐⭐"
    }
  ],

  "experiments": [
    {
      "id": "exp1_no_dropout",
      "name": "實驗 1: 移除 Dropout",
      "hypothesis_id": 1,
      "script": "try/experiment_1_no_dropout.sh",
      "variables": {
        "changed": {
          "dropout": 0.0
        },
        "unchanged": {
          "weight_decay": 0.01,
          "dataset_size": "240+",
          "batch_size": 14,
          "learning_rate": 3e-4,
          "num_epochs": 200
        }
      },
      "expected_results": {
        "if_major_factor": "epoch_200_accuracy > 40%",
        "if_moderate_factor": "epoch_200_accuracy ~ 25-30%",
        "if_minor_factor": "epoch_200_accuracy ~ 20%"
      },
      "status": "pending"
    },
    {
      "id": "exp2_no_weight_decay",
      "name": "實驗 2: 移除 Weight Decay",
      "hypothesis_id": 2,
      "script": "try/experiment_2_no_weight_decay.sh",
      "variables": {
        "changed": {
          "weight_decay": 0.0
        },
        "unchanged": {
          "dropout": 0.3,
          "dataset_size": "240+",
          "batch_size": 14,
          "learning_rate": 3e-4,
          "num_epochs": 200
        }
      },
      "expected_results": {
        "if_major_factor": "epoch_200_accuracy > 35%",
        "if_moderate_factor": "epoch_200_accuracy ~ 25-30%",
        "if_minor_factor": "epoch_200_accuracy ~ 20%"
      },
      "status": "pending"
    },
    {
      "id": "exp3_mini_dataset",
      "name": "實驗 3: 小資料集 (14個音檔)",
      "hypothesis_id": 3,
      "script": "try/experiment_3_mini_dataset.sh",
      "variables": {
        "changed": {
          "dataset_size": 14,
          "dropout": 0.0
        },
        "unchanged": {
          "weight_decay": 0.01,
          "batch_size": 14,
          "learning_rate": 3e-4,
          "num_epochs": 200
        }
      },
      "expected_results": {
        "if_major_factor": "epoch_100_accuracy > 90%",
        "if_moderate_factor": "epoch_100_accuracy ~ 60-80%",
        "if_minor_factor": "epoch_100_accuracy < 50%"
      },
      "priority": "highest",
      "status": "pending"
    }
  ],

  "execution_plan": {
    "recommended_order": [
      "exp3_mini_dataset (最快，最可能的主因)",
      "exp1_no_dropout (理論依據強)",
      "exp2_no_weight_decay (影響較小)"
    ],
    "parallel_execution": false,
    "reason": "每個實驗需要獨立驗證，避免 GPU 資源競爭"
  },

  "analysis_criteria": {
    "success_metric": "Train Accuracy at Epoch 200",
    "comparison_baseline": "run_simple_efficient_original (~20% at epoch 200)",
    "improvement_threshold": {
      "minor": "+5%",
      "moderate": "+10%",
      "major": "+20%"
    }
  },

  "file_paths": {
    "logs": "logs/exp*_*.log",
    "results": "results/exp*/",
    "mini_dataset": "data/mini_dataset/",
    "documentation": "try/EXPERIMENTS_README.md"
  }
}
