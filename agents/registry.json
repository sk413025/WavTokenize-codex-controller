{
  "schema_version": 1,
  "authority_source": "AGENTS.md",
  "native_harness": {
    "config": ".codex/config.toml",
    "skills_root": ".agents/skills"
  },
  "top_level_controller": "codex",
  "agents": [
    {
      "agent_id": "codex",
      "role": "controller",
      "native_role": "default",
      "first_class": true,
      "policy_scope": ["select_manifest", "delegate", "edit_code", "launch_run", "supersede_run", "promote_run"],
      "outputs": ["controller_decision", "queued_followup"],
      "preferred_skills": ["controller-decomposition", "experiment-promotion"],
      "handoff_to": ["planner", "executor", "monitor", "analyst", "maintainer"]
    },
    {
      "agent_id": "planner",
      "role": "planner",
      "native_role": "planner",
      "fallback_native_role": "explorer",
      "first_class": true,
      "policy_scope": ["manifest_design", "hypothesis_update", "next_manifest_generation"],
      "outputs": ["plan", "manifest_revision", "next_manifest"],
      "preferred_skills": ["controller-decomposition", "manifest-authoring"],
      "handoff_to": ["executor", "analyst", "codex"]
    },
    {
      "agent_id": "executor",
      "role": "executor",
      "native_role": "worker",
      "first_class": true,
      "policy_scope": ["prepare_env", "run_stage", "resume_stage"],
      "outputs": ["stage_result", "artifact_report"],
      "preferred_skills": ["manifest-authoring", "legacy-adapter-onboarding"],
      "handoff_to": ["monitor", "analyst", "codex"]
    },
    {
      "agent_id": "monitor",
      "role": "monitor",
      "native_role": "monitor",
      "first_class": true,
      "policy_scope": ["observe_run", "capture_failure", "check_artifacts"],
      "outputs": ["monitor_report", "failure_capture"],
      "preferred_skills": ["run-diagnosis"],
      "handoff_to": ["analyst", "executor", "codex"]
    },
    {
      "agent_id": "analyst",
      "role": "analyst",
      "native_role": "analyst",
      "fallback_native_role": "explorer",
      "first_class": true,
      "policy_scope": ["classify_result", "diagnose", "compare_baseline", "promote_memory"],
      "outputs": ["analysis", "diagnosis", "baseline_comparison"],
      "preferred_skills": ["run-diagnosis", "experiment-promotion"],
      "handoff_to": ["maintainer", "planner", "codex"]
    },
    {
      "agent_id": "maintainer",
      "role": "maintainer",
      "native_role": "maintainer",
      "fallback_native_role": "worker",
      "first_class": true,
      "policy_scope": ["patch_intent", "code_change_request", "manifest_change_request"],
      "outputs": ["patch_request"],
      "preferred_skills": ["legacy-adapter-onboarding", "manifest-authoring"],
      "handoff_to": ["planner", "codex"]
    }
  ]
}
